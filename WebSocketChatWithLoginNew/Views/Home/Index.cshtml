@model IEnumerable<WebsocketChatwithLoginContext.Models.Message>
@{
    ViewData["Title"] = "Home Page";
}

@if(User.Identity.IsAuthenticated)
{
    <div class="container py-4" style="max-width:620px">
        <div class="card shadow-sm">

            <div class="card-header d-flex align-items-center gap-2 bg-white">
                <span class="fs-5">💬</span>
                <div>
                    <div class="fw-semibold">General Chat</div>
                    <small class="text-success">Welcome to the Chat!</small>
                </div>
            </div>

            <div class="card-body p-3" id="chatBoxId">
                @foreach(var message in Model)
                {
                    <div>
                        <div class="text-muted small mb-1">${esc(userName)}</div>
                        <div class="bubble">@message.MesMessage</div>
                    </div>
                }
            </div>

            <div class="card-footer bg-white">
                <div class="input-group">
                    <input id="messageInputId" class="form-control" rows="1"
                           placeholder="Type a message…"
                           style="resize:none;overflow:hidden"/>
                    <button class="btn btn-primary" id="sendMessageId">Send</button>
                </div>
                <small class="text-muted">Enter to send · Shift+Enter for new line</small>
            </div>

        </div>
    </div>
}
else
{
    <h1>Register and Log in to Chat!</h1>
}
<script src="~/microsoft/signalr/dist/browser/signalr.js"></script>
<script src="~/js/chat.js"></script>

