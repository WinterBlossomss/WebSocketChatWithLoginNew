@model IEnumerable<WebSocketChatWithLoginNew.ViewModels.MessageViewModel>
@{
    ViewData["Title"] = "Home Page";
}

@if(User.Identity.IsAuthenticated)
{
    <div class="container py-4" style="max-width:620px">
        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center gap-2 bg-white">
                <span class="fs-5">💬</span>
                <div>
                    <div class="fw-semibold">General Chat</div>
                    <small class="text-success">Welcome to the Chat!</small>
                </div>
            </div>

            <div id="chatBoxId" class="card-body p-3" data-current-user-id="@ViewBag.CurrentUserId">
                @foreach (var message in Model)
                {
                    var isSent = message.UserId == ViewBag.CurrentUserId as string;
                    var side = isSent ? "sent" : "recv";
                    var initials = (message.UserName ?? "?").Substring(0, Math.Min(2, (message.UserName ?? "?").Length)).ToUpper();

                    <div class="msg-row @side" data-message-id="@message.Id">
                        <div class="avatar-initials">@initials</div>
                        <div class="msg-inner">
                            <div class="msg-name">@message.UserName</div>
                            <div class="bubble">@message.Text</div>
                            @if (isSent)
                            {
                                <div class="msg-actions">
                                    <button class="msg-btn edit-btn" id="deleteBtn" data-id="@message.Id">Edit</button>
                                    <button class="msg-btn delete-btn" id="editBtn" data-id="@message.Id">Delete</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="card-footer bg-white">
                <div class="input-group">
                    <input id="messageInputId" class="form-control" rows="1"
                           placeholder="Type a message…"
                           style="resize:none;overflow:hidden"/>
                    <button class="btn btn-primary" id="sendMessageId">Send</button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <h1>Register and Log in to Chat!</h1>
}
<script src="~/microsoft/signalr/dist/browser/signalr.js"></script>
<script src="~/js/chat.js"></script>

